# =============================================================================
# ATS Recruitment — Environment Variables
# Copy this file to .env and fill in values before starting services.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ats_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Go API
# ---------------------------------------------------------------------------
PORT=8080
DATABASE_URL=postgres://ats_user:change_me_in_production@postgres:5432/ats_db?sslmode=disable
JWT_SECRET=change_me_minimum_32_chars_secret_key
JWT_EXPIRY_MINUTES=30

# ---------------------------------------------------------------------------
# FastAPI AI Service
# ---------------------------------------------------------------------------
AI_SERVICE_URL=http://ai-service:8000
AI_MODEL_NAME=all-MiniLM-L6-v2
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# SMTP (Transactional Email)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@tigersoft.com

# ---------------------------------------------------------------------------
# Next.js apps
# ---------------------------------------------------------------------------
# For apps/main and apps/portal (client-side visible)
NEXT_PUBLIC_API_URL=http://localhost:8080
